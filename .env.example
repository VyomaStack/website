# Public site URL (used for sitemap, Open Graph, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://www.vyomastack.com

# ── AI — Google Gemini (FREE tier) ──
#
# 1. Go to https://aistudio.google.com/apikey
# 2. Click "Create API key" (no credit card required)
# 3. Add in Vercel → Settings → Environment Variables → Redeploy
GEMINI_API_KEY=AIza...
# Optional: override model (default: gemini-2.0-flash-lite — best free tier limits)
# GEMINI_MODEL=gemini-2.0-flash-lite

# ── Analytics (optional) ──
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx
