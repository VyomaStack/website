# Public site URL (used for sitemap, Open Graph, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://www.vyomastack.com

# ── AI (required for SQL Explain & Spark Advisor) ──
#
# Get your key at https://platform.openai.com/api-keys
# Add in Vercel → Settings → Environment Variables → Redeploy
OPENAI_API_KEY=sk-...
# Optional: override model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# ── Analytics (optional) ──
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx
