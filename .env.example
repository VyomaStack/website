# Public site URL (used for sitemap, Open Graph, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://www.vyomastack.com

# ── Analytics (add in Vercel → Settings → Environment Variables) ──
#
# Google Analytics 4:
#   1. Go to https://analytics.google.com → Admin → Create Property
#   2. Copy Measurement ID (starts with G-)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
#
# Microsoft Clarity:
#   1. Go to https://clarity.microsoft.com → Add project
#   2. Copy Project ID from Settings → Overview
# NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx
