{
  "manifest_version": 3,
  "name": "VyomaStack — Dev Tools",
  "version": "0.1.0",
  "description": "Format SQL, JSON, and decode JWT instantly from any page. Opens the full VyomaStack AI workspace.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "VyomaStack",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["contextMenus", "storage", "activeTab", "scripting"],
  "host_permissions": ["https://www.vyomastack.com/*"],
  "homepage_url": "https://www.vyomastack.com"
}
